---
import { jams } from '../data/jams';

const BASE = import.meta.env.BASE_URL;

type JamEntry = typeof jams[number];

const byYear = new Map<number, JamEntry[]>();
for (const j of jams) {
  const y = new Date(j.date).getFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(j);
}
const years = Array.from(byYear.keys()).sort((a, b) => b - a);

const formatDate = (iso: string) =>
  new Date(iso).toLocaleDateString('en-US', {
    month: 'short',
    day: '2-digit',
    timeZone: 'UTC',
  }).toUpperCase();

const isSpeed = (name: string) => /speedjam|foddian/i.test(name);
---

