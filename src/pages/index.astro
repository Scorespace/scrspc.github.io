---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ScoreSpace - Make games. Play games.">
  <section class="diagonal-split">
    <div class="hero-split fade-in fade-in-delay-1">
      <div class="hero-bg" aria-hidden="true">
        <div class="stars"></div>
        <div class="star-twinkle twinkle-1"></div>
        <div class="star-twinkle twinkle-2"></div>
        <div class="star-twinkle twinkle-3"></div>
        <div class="star-twinkle twinkle-4"></div>
        <div class="star-twinkle twinkle-5"></div>
      </div>
      <h1 class="reveal-text">
        <span class="line-1">
          <span class="word">SCORESPACE</span>
          <span class="word">IS</span>
          <span class="word">A</span>
        </span>
        <span class="line-2">
          <span class="word cyan">COMMUNITY</span>
          <span class="word cyan">POWERED</span>
        </span>
        <span class="line-3">
          <span class="word purple nowrap">GAME PUBLISHER</span>
        </span>
      </h1>
      <div class="hero-stats">
        <div class="icon-stat cyan-stat">
          <span class="stat-icon">💻</span>
          <span class="stat-number" data-count-to="120" data-count-suffix="+">0+</span>
          <span class="stat-label">Avg Monthly<br/>Submissions</span>
        </div>
        <div class="icon-stat purple-stat">
          <span class="stat-icon">🎮</span>
          <span class="stat-number" data-count-to="5" data-count-suffix="M+">0M+</span>
          <span class="stat-label">Lifetime<br/>Players</span>
        </div>
      </div>
    </div>

    <div class="pipeline-section">
      <h2 class="pipeline-heading scroll-fade-in">HOW WE PUBLISH</h2>
      <div class="stepper scroll-fade-in">
        <div class="stepper-track">
          <div class="stepper-fill"></div>
        </div>
        <button class="stepper-node active" data-step="0"><span>01</span></button>
        <button class="stepper-node" data-step="1"><span>02</span></button>
        <button class="stepper-node" data-step="2"><span>03</span></button>
      </div>
      <div class="stepper-panels scroll-fade-in">
        <div class="stepper-panel active" data-panel="0">
          <div class="panel-bg-text" aria-hidden="true">JAMS</div>
          <div class="panel-content">
            <h3 class="panel-title cyan-text">GENERATE</h3>
            <p class="panel-desc">Our monthly game jams produce fresh concepts from a global community of developers.</p>
          </div>
        </div>
        <div class="stepper-panel" data-panel="1">
          <div class="panel-bg-text" aria-hidden="true">TEST</div>
          <div class="panel-content">
            <h3 class="panel-title blend-text">VALIDATE</h3>
            <p class="panel-desc">Top games get a live test with real players to prove the concept before we go bigger.</p>
          </div>
        </div>
        <div class="stepper-panel" data-panel="2">
          <div class="panel-bg-text" aria-hidden="true">PUBLISH</div>
          <div class="panel-content">
            <h3 class="panel-title purple-text">SCALE</h3>
            <p class="panel-desc">Proven hits get full publishing support, monetization, and a dedicated team to grow.</p>
          </div>
        </div>
      </div>
      <div class="stepper-nav scroll-fade-in">
        <button class="stepper-prev" disabled>← Prev</button>
        <button class="stepper-next">Next →</button>
      </div>
    </div>

    <div class="split-container">
      <a href={`${import.meta.env.BASE_URL}jams/`} class="split-side split-jams fade-in fade-in-delay-2">
        <div class="split-content">
          <h2>JAMS</h2>
          <p class="split-tagline">Join the community</p>
          <div class="split-countdown">
            <span class="countdown-mini" id="countdown-mini">Next jam in <strong id="days-mini">--</strong>d <strong id="hours-mini">--</strong>h</span>
          </div>
          <span class="split-cta">Enter →</span>
        </div>
      </a>

      <a href={`${import.meta.env.BASE_URL}games/`} class="split-side split-games fade-in fade-in-delay-3">
        <div class="split-content">
          <h2>GAMES</h2>
          <p class="split-tagline">Get published</p>
          <p class="split-description">From jam to published</p>
          <span class="split-cta">Enter →</span>
        </div>
      </a>
    </div>
  </section>
</Layout>

<style>
  /* Diagonal Split Hero */
  .diagonal-split {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
  }

  .stars {
    position: absolute;
    width: 100%;
    height: 100%;
    background-image:
      radial-gradient(1px 1px at 10% 15%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1px 1px at 25% 35%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 40% 8%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 55% 45%, rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 70% 20%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 85% 55%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 15% 60%, rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 50% 70%, rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 90% 40%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 35% 80%, rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 5% 50%, rgba(255,255,255,0.5) 0%, transparent 100%),
      radial-gradient(1.5px 1.5px at 65% 10%, rgba(255,255,255,0.4) 0%, transparent 100%),
      radial-gradient(1px 1px at 78% 72%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 20% 90%, rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 95% 85%, rgba(255,255,255,0.35) 0%, transparent 100%),
      radial-gradient(1px 1px at 45% 25%, rgba(255,255,255,0.3) 0%, transparent 100%),
      radial-gradient(1px 1px at 60% 60%, rgba(255,255,255,0.25) 0%, transparent 100%),
      radial-gradient(1px 1px at 30% 50%, rgba(255,255,255,0.3) 0%, transparent 100%);
  }

  .star-twinkle {
    position: absolute;
    width: 2px;
    height: 2px;
    border-radius: 50%;
    background: white;
    animation: twinkle 3s ease-in-out infinite;
  }

  .twinkle-1 { top: 12%; left: 22%; animation-delay: 0s; }
  .twinkle-2 { top: 40%; left: 75%; animation-delay: 1.2s; }
  .twinkle-3 { top: 65%; left: 45%; animation-delay: 2.4s; }
  .twinkle-4 { top: 25%; left: 88%; animation-delay: 0.8s; }
  .twinkle-5 { top: 80%; left: 15%; animation-delay: 1.8s; }

  @keyframes twinkle {
    0%, 100% { opacity: 0.2; }
    50% { opacity: 0.8; }
  }

  .hero-split {
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 6rem 2rem 3rem;
    max-width: 100%;
    margin: 0;
    gap: 2.5rem;
  }

  .hero-split h1 {
    font-size: 4rem;
    font-weight: 900;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .reveal-text .line-1,
  .reveal-text .line-2,
  .reveal-text .line-3 {
    display: block;
  }

  .reveal-text .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    animation: revealWord 0.5s ease forwards;
  }

  .reveal-text .line-1 .word:nth-child(1) { animation-delay: 0.1s; }
  .reveal-text .line-1 .word:nth-child(2) { animation-delay: 0.2s; }
  .reveal-text .line-1 .word:nth-child(3) { animation-delay: 0.3s; }

  .reveal-text .line-2 .word:nth-child(1) { animation-delay: 0.5s; }
  .reveal-text .line-2 .word:nth-child(2) { animation-delay: 0.6s; }

  .reveal-text .line-3 .word:nth-child(1) { animation-delay: 0.8s; }

  .nowrap {
    white-space: nowrap;
  }

  @keyframes revealWord {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-split h1 .cyan {
    color: var(--color-jams);
  }

  .hero-split h1 .purple {
    color: var(--color-games);
  }

  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 4rem;
  }

  .icon-stat {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .icon-stat .stat-icon {
    font-size: 2.5rem;
  }

  .icon-stat .stat-number {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
  }

  .cyan-stat .stat-number {
    color: var(--color-jams);
  }

  .purple-stat .stat-number {
    color: var(--color-games);
  }

  .icon-stat .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.3;
  }

  .split-container {
    display: flex;
    flex: 1;
    position: relative;
  }

  .split-side {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12rem 2rem;
    text-decoration: none;
    color: var(--color-text);
    transition: flex 0.4s ease, background-color 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .split-jams {
    background: linear-gradient(135deg, rgba(6, 190, 252, 0.15) 0%, rgba(6, 190, 252, 0.05) 100%);
    clip-path: polygon(0 0, 100% 0, 85% 100%, 0 100%);
    padding-right: 4rem;
  }

  .split-jams::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-left: 3px solid var(--color-jams);
    opacity: 0.5;
  }

  .split-games {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(139, 92, 246, 0.15) 100%);
    clip-path: polygon(15% 0, 100% 0, 100% 100%, 0 100%);
    margin-left: -15%;
    padding-left: 4rem;
  }

  .split-games::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-right: 3px solid var(--color-games);
    opacity: 0.5;
  }

  .split-side:hover {
    flex: 1.15;
  }

  .split-jams:hover {
    background: linear-gradient(135deg, rgba(6, 190, 252, 0.25) 0%, rgba(6, 190, 252, 0.1) 100%);
  }

  .split-games:hover {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(139, 92, 246, 0.25) 100%);
  }

  .split-content {
    text-align: center;
    max-width: 300px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .split-content h2 {
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
    letter-spacing: 0.1em;
  }

  .split-jams .split-content h2 {
    color: var(--color-jams);
  }

  .split-games .split-content h2 {
    color: var(--color-games);
  }

  .split-tagline {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .split-countdown,
  .split-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .countdown-mini strong {
    color: var(--color-jams);
  }

  .split-cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .split-jams .split-cta {
    border: 2px solid var(--color-jams);
    color: var(--color-jams);
  }

  .split-jams:hover .split-cta {
    background-color: var(--color-jams);
    color: var(--color-bg);
  }

  .split-games .split-cta {
    border: 2px solid var(--color-games);
    color: var(--color-games);
  }

  .split-games:hover .split-cta {
    background-color: var(--color-games);
    color: var(--color-bg);
  }

  /* Publishing Pipeline - Progress Bar Stepper */
  .pipeline-section {
    padding: 8rem 2rem;
  }

  .pipeline-heading {
    text-align: center;
    font-size: 2rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    margin-bottom: 3rem;
    color: var(--color-text);
  }

  .stepper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 500px;
    margin: 0 auto 2.5rem;
  }

  .stepper-track {
    position: absolute;
    top: 50%;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--color-border);
    transform: translateY(-50%);
    z-index: 0;
    border-radius: 1px;
  }

  .stepper-fill {
    height: 100%;
    width: 0%;
    background: linear-gradient(90deg, var(--color-jams), #6b8af9, var(--color-games));
    border-radius: 1px;
    transition: width 0.4s ease;
  }

  .stepper-node {
    position: relative;
    z-index: 1;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 2px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 900;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .stepper-node:hover {
    border-color: var(--color-text-muted);
  }

  .stepper-node.active {
    color: var(--color-text);
    transform: scale(1.15);
  }

  .stepper-node[data-step="0"].active {
    border-color: var(--color-jams);
    box-shadow: 0 0 12px rgba(6, 190, 252, 0.3);
  }

  .stepper-node[data-step="1"].active {
    border-color: #6b8af9;
    box-shadow: 0 0 12px rgba(107, 138, 249, 0.3);
  }

  .stepper-node[data-step="2"].active {
    border-color: var(--color-games);
    box-shadow: 0 0 12px rgba(139, 92, 246, 0.3);
  }

  .stepper-node.visited {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  .stepper-panels {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    min-height: 14rem;
    overflow: hidden;
  }

  .stepper-panel {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.4s ease, transform 0.4s ease;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 14rem;
  }

  .stepper-panel.active {
    position: relative;
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .panel-bg-text {
    position: absolute;
    font-size: 10rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    opacity: 0.05;
    user-select: none;
    pointer-events: none;
    line-height: 1;
    white-space: nowrap;
    color: var(--color-text);
  }

  .panel-content {
    position: relative;
    z-index: 1;
    text-align: center;
  }

  .panel-title {
    font-size: 3rem;
    font-weight: 900;
    letter-spacing: 0.05em;
    line-height: 1;
    margin-bottom: 1rem;
  }

  .panel-title.cyan-text { color: var(--color-jams); }
  .panel-title.blend-text { color: #6b8af9; }
  .panel-title.purple-text { color: var(--color-games); }

  .panel-desc {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    max-width: 500px;
    margin: 0 auto;
  }

  .stepper-nav {
    display: flex;
    justify-content: center;
    gap: 1rem;
    max-width: 700px;
    margin: 0 auto;
  }

  .stepper-prev,
  .stepper-next {
    padding: 0.6rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-muted);
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .stepper-prev:hover:not(:disabled),
  .stepper-next:hover:not(:disabled) {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  .stepper-prev:disabled,
  .stepper-next:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  @media (max-width: 768px) {
    .pipeline-section {
      padding: 5rem 1.5rem;
    }

    .stepper {
      max-width: 280px;
    }

    .panel-bg-text {
      font-size: 5rem;
    }

    .panel-title {
      font-size: 2rem;
    }
  }

  @media (max-width: 768px) {
    .diagonal-split {
      min-height: auto;
    }

    .split-container {
      flex-direction: column;
    }

    .split-side {
      clip-path: none;
      margin: 0;
      padding: 3rem 2rem;
    }

    .split-jams {
      padding-right: 2rem;
      border-bottom: 1px solid var(--color-border);
    }

    .split-games {
      padding-left: 2rem;
      margin-left: 0;
    }

    .split-side:hover {
      flex: 1;
    }

    .split-content h2 {
      font-size: 2rem;
    }

    .hero-split {
      padding: 4rem 1.5rem 2rem;
      gap: 1.5rem;
    }

    .hero-split h1 {
      font-size: 2rem;
    }

    .hero-stats {
      gap: 2rem;
    }

    .icon-stat .stat-number {
      font-size: 2.5rem;
    }

    .icon-stat .stat-icon {
      font-size: 2rem;
    }
  }

  .btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: var(--color-text);
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    color: var(--color-text);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-jams);
  }

  .btn-secondary:hover {
    background-color: var(--color-jams);
    color: var(--color-bg);
  }


</style>

<script>
  // Countdown to next 3rd Friday at 3pm EST
  function getThirdFriday(year: number, month: number): Date {
    const firstDay = new Date(year, month, 1);
    const firstFriday = new Date(year, month, 1 + ((5 - firstDay.getDay() + 7) % 7));
    const thirdFriday = new Date(firstFriday);
    thirdFriday.setDate(firstFriday.getDate() + 14);
    // Set to 3pm EST (20:00 UTC)
    thirdFriday.setUTCHours(20, 0, 0, 0);
    return thirdFriday;
  }

  function getNextThirdFriday(): Date {
    const now = new Date();
    let year = now.getFullYear();
    let month = now.getMonth();

    let thirdFriday = getThirdFriday(year, month);

    if (now >= thirdFriday) {
      month++;
      if (month > 11) {
        month = 0;
        year++;
      }
      thirdFriday = getThirdFriday(year, month);
    }

    return thirdFriday;
  }

  function updateCountdown() {
    const target = getNextThirdFriday();
    const now = new Date();
    const diff = target.getTime() - now.getTime();

    if (diff <= 0) {
      location.reload();
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));

    // Update mini countdown on diagonal split
    const daysMiniEl = document.getElementById('days-mini');
    const hoursMiniEl = document.getElementById('hours-mini');

    if (daysMiniEl) daysMiniEl.textContent = days.toString();
    if (hoursMiniEl) hoursMiniEl.textContent = hours.toString();
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);

  // Count-up animation for hero stats
  function animateCount(el: HTMLElement) {
    const target = parseInt(el.dataset.countTo!, 10);
    const suffix = el.dataset.countSuffix || '';
    const duration = 1500;
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // Ease-out quad
      const eased = 1 - (1 - progress) * (1 - progress);
      const current = Math.round(eased * target);
      el.textContent = current + suffix;
      if (progress < 1) {
        requestAnimationFrame(tick);
      }
    }

    requestAnimationFrame(tick);
  }

  const countEls = document.querySelectorAll<HTMLElement>('[data-count-to]');
  const countObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCount(entry.target as HTMLElement);
        countObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  countEls.forEach(el => countObserver.observe(el));

  // Progress bar stepper
  const nodes = document.querySelectorAll<HTMLElement>('.stepper-node');
  const panels = document.querySelectorAll<HTMLElement>('.stepper-panel');
  const fill = document.querySelector<HTMLElement>('.stepper-fill');
  const prevBtn = document.querySelector<HTMLButtonElement>('.stepper-prev');
  const nextBtn = document.querySelector<HTMLButtonElement>('.stepper-next');
  let current = 0;

  function goToStep(idx: number) {
    current = idx;
    nodes.forEach((n, i) => {
      n.classList.toggle('active', i === idx);
      n.classList.toggle('visited', i < idx);
    });
    panels.forEach(p => p.classList.remove('active'));
    panels[idx]?.classList.add('active');
    if (fill) fill.style.width = `${(idx / (nodes.length - 1)) * 100}%`;
    if (prevBtn) prevBtn.disabled = idx === 0;
    if (nextBtn) nextBtn.disabled = idx === nodes.length - 1;
  }

  nodes.forEach(node => {
    node.addEventListener('click', () => goToStep(parseInt(node.dataset.step!, 10)));
  });

  prevBtn?.addEventListener('click', () => { if (current > 0) goToStep(current - 1); });
  nextBtn?.addEventListener('click', () => { if (current < nodes.length - 1) goToStep(current + 1); });

</script>
