<script is:inline>
(function () {
  function nextThirdFriday() {
    var now = new Date();
    var y = now.getFullYear(), m = now.getMonth();
    var tf = function (yy, mm) {
      var f = new Date(yy, mm, 1);
      var ff = new Date(yy, mm, 1 + ((5 - f.getDay() + 7) % 7));
      var t = new Date(ff);
      t.setDate(ff.getDate() + 14);
      t.setUTCHours(20, 0, 0, 0);
      return t;
    };
    var t = tf(y, m);
    if (now >= t) { m++; if (m > 11) { m = 0; y++; } t = tf(y, m); }
    return t;
  }
  function pad(n) { return String(n).padStart(2, '0'); }
  function tick() {
    var diff = nextThirdFriday() - new Date();
    if (diff <= 0) return;
    var d = Math.floor(diff / 864e5);
    var h = Math.floor((diff % 864e5) / 36e5);
    var mm = Math.floor((diff % 36e5) / 6e4);
    ['cd-d', 'hm-days'].forEach(function (id) {
      var e = document.getElementById(id); if (e) e.textContent = d;
    });
    ['cd-h', 'hm-hours'].forEach(function (id) {
      var e = document.getElementById(id); if (e) e.textContent = pad(h);
    });
    var me = document.getElementById('cd-m');
    if (me) me.textContent = pad(mm);
  }
  tick();
  setInterval(tick, 30000);
})();
</script>

<style is:global>
  :root {
    --ink:      #0a0b1f;
    --ink-2:    #0f1130;
    --ink-3:    #161944;
    --line:     rgba(255,255,255,.10);
    --line-2:   rgba(255,255,255,.05);
    --fog:      rgba(255,255,255,.72);
    --mute:     rgba(255,255,255,.50);
    --cyan:     #06befc;
    --violet:   #7a2bff;
    --cyan-soft:#8fd7ff;
    --violet-soft:#c6a6ff;

    --head: 'Russo One', system-ui, sans-serif;
    --body: 'Lato', system-ui, sans-serif;

    --maxw: 1240px;
    --gutter: clamp(20px, 4vw, 48px);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html, body {
    background: var(--ink);
    color: #fff;
    font-family: var(--body);
    font-weight: 400;
    overflow-x: hidden;
  }
  body {
    font-size: 16px;
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    letter-spacing: .005em;
  }
  a { color: inherit; text-decoration: none; }
  img { max-width: 100%; display: block; }
  button { font: inherit; cursor: pointer; border: 0; background: none; color: inherit; }

  .container { max-width: var(--maxw); margin: 0 auto; padding: 0 var(--gutter); }

  h1, h2, h3, h4 {
    font-family: var(--head);
    font-weight: 400;
    letter-spacing: -.01em;
    line-height: 1;
  }
  .kicker {
    font-family: var(--head);
    font-size: 12px;
    letter-spacing: .24em;
    text-transform: uppercase;
    color: var(--cyan);
  }

  /* NAV */
  .nav {
    position: sticky; top: 0; z-index: 50;
    background: rgba(10,11,31,.85);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--line);
  }
  .nav-inner {
    max-width: var(--maxw); margin: 0 auto;
    padding: 18px var(--gutter);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 20px;
  }
  .brand {
    display: flex; align-items: center; gap: 12px;
    font-family: var(--head); font-size: 16px; letter-spacing: .02em;
  }
  .brand-dot {
    width: 14px; height: 14px; border-radius: 50%;
    background: conic-gradient(from 210deg, var(--cyan), var(--violet), var(--cyan));
    box-shadow: 0 0 16px rgba(6,190,252,.55);
    animation: spin 6s linear infinite;
  }
  @keyframes spin { to { transform: rotate(360deg); } }
  .nav-links {
    display: flex; justify-content: center; gap: 36px;
    font-family: var(--head); font-size: 13px; letter-spacing: .06em; text-transform: uppercase;
  }
  .nav-links a {
    color: var(--fog);
    position: relative; padding: 4px 0;
    transition: color .2s ease;
  }
  .nav-links a:hover { color: #fff; }
  .nav-links a::after {
    content: ""; position: absolute; left: 0; right: 0; bottom: -4px;
    height: 2px; background: var(--cyan);
    transform: scaleX(0); transform-origin: left;
    transition: transform .3s ease;
  }
  .nav-links a:hover::after { transform: scaleX(1); }
  .nav-cta { justify-self: end; }
  .btn-chip {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 11px 18px; border: 1px solid var(--line);
    font-family: var(--head); font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
    border-radius: 999px; transition: all .2s ease;
  }
  .btn-chip:hover { border-color: var(--cyan); color: var(--cyan); transform: translateY(-1px); }
  .pulse {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--cyan);
    box-shadow: 0 0 0 0 rgba(6,190,252,.7);
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 rgba(6,190,252,.7); }
    70%  { box-shadow: 0 0 0 10px rgba(6,190,252,0); }
    100% { box-shadow: 0 0 0 0 rgba(6,190,252,0); }
  }

  /* HERO */
  .hero {
    position: relative; overflow: hidden;
    padding: clamp(80px, 14vh, 160px) 0 clamp(100px, 16vh, 180px);
  }
  .hero-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
  .hero-bg .orb { position: absolute; border-radius: 50%; filter: blur(100px); opacity: .45; }
  .hero-bg .orb.a {
    width: 720px; height: 720px; left: -180px; top: -220px;
    background: radial-gradient(circle, var(--violet), transparent 60%);
  }
  .hero-bg .orb.b {
    width: 600px; height: 600px; right: -180px; top: 180px;
    background: radial-gradient(circle, var(--cyan), transparent 60%);
  }
  .hero-bg .dots {
    position: absolute; inset: 0;
    background-image: radial-gradient(circle, rgba(255,255,255,.08) 1.2px, transparent 1.2px);
    background-size: 36px 36px;
    mask-image: radial-gradient(ellipse at 50% 40%, #000 40%, transparent 80%);
  }
  .hero .container { position: relative; }
  .hero h1 {
    font-size: clamp(44px, 7vw, 104px);
    letter-spacing: -.02em; line-height: .98;
    max-width: 18ch;
  }
  .hero h1 .accent-c { color: var(--cyan); }
  .hero h1 .accent-v { color: var(--violet-soft); }
  .hero h1 .swish { display: inline-block; }
  .hero .deck {
    max-width: 560px; margin-top: 36px;
    font-size: 19px; line-height: 1.6; color: var(--fog); font-weight: 300;
  }
  .hero .deck b { color: #fff; font-weight: 700; }
  .hero .row { margin-top: 52px; display: flex; gap: 16px; align-items: center; flex-wrap: wrap; }

  .btn {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 16px 26px;
    font-family: var(--head); font-size: 13px; letter-spacing: .1em; text-transform: uppercase;
    border: 2px solid #fff; color: #fff; background: transparent;
    border-radius: 999px;
    transition: all .2s ease;
  }
  .btn:hover { background: #fff; color: var(--ink); transform: translateY(-2px); }
  .btn.primary { background: var(--cyan); color: var(--ink); border-color: var(--cyan); }
  .btn.primary:hover { background: #fff; border-color: #fff; }
  .btn .arrow { transition: transform .2s ease; }
  .btn:hover .arrow { transform: translateX(4px); }

  .hero-clock {
    display: inline-flex; align-items: center; gap: 14px;
    padding: 10px 18px; border: 1px solid var(--line); border-radius: 999px;
    font-family: var(--head); font-size: 12px; letter-spacing: .14em; text-transform: uppercase; color: var(--fog);
  }
  .hero-clock b { color: var(--cyan); font-weight: 400; }

  /* MARQUEE STRIP */
  .strip {
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 22px 0;
    overflow: hidden;
    font-family: var(--head); font-size: 32px; letter-spacing: -.01em;
    color: var(--fog);
  }
  .strip-track {
    display: inline-flex; white-space: nowrap;
    animation: slide 40s linear infinite;
    gap: 56px; padding-left: 56px; align-items: center;
  }
  .strip-track span.dot { color: var(--cyan); font-size: 24px; }
  .strip-track span.vio { color: var(--violet-soft); }
  @keyframes slide { to { transform: translateX(-50%); } }

  /* SECTION SHELL */
  section.panel { padding: clamp(80px, 14vw, 180px) 0; position: relative; }
  .sec-head { max-width: 900px; margin-bottom: 72px; }
  .sec-head .kicker { margin-bottom: 20px; display: block; }
  .sec-head h2 { font-size: clamp(44px, 6.5vw, 104px); letter-spacing: -.02em; }
  .sec-head h2 .accent-c { color: var(--cyan); }
  .sec-head h2 .accent-v { color: var(--violet-soft); }
  .sec-head p.lede {
    margin-top: 24px; font-size: 18px; color: var(--fog);
    max-width: 640px; font-weight: 300; line-height: 1.7;
  }

  /* JAMS BOXES */
  .jams-boxes {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .jbox {
    position: relative;
    border-radius: 20px;
    padding: 0;
    display: flex; flex-direction: column;
    background: transparent;
    border: 1.5px solid var(--cyan);
    overflow: hidden;
  }
  .jbox-media {
    position: relative;
    aspect-ratio: 16/9;
    border: 0;
    border-bottom: 1.5px solid var(--cyan);
    border-radius: 0;
    background: rgba(6,190,252,.04);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
  }
  .jbox-media .ph-cross {
    position: absolute; inset: 0; width: 100%; height: 100%;
    stroke: var(--cyan); stroke-width: 1; opacity: .35;
  }
  .jbox-media .ph-label {
    position: relative; z-index: 1;
    font-family: var(--head); font-size: 12px; letter-spacing: .2em; text-transform: uppercase;
    color: var(--cyan);
    background: var(--ink);
    padding: 6px 14px;
    border: 1px solid var(--cyan);
    border-radius: 999px;
  }
  .jbox-title {
    font-family: var(--head);
    font-size: clamp(28px, 3vw, 40px);
    letter-spacing: -.01em;
    color: #fff;
    padding: 28px 28px 0;
  }
  .jbox-desc {
    color: var(--fog);
    font-size: 15px;
    line-height: 1.65;
    font-weight: 300;
    padding: 14px 28px 28px;
    max-width: 52ch;
  }

  @media (max-width: 980px) {
    .jams-boxes { grid-template-columns: 1fr; gap: 16px; }
  }

  /* PUBLISHING */
  .pub-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 32px; }
  .pub {
    padding: 40px 0;
    display: flex; flex-direction: column; gap: 20px;
    position: relative;
    border-top: 2px solid #fff;
  }
  .pub:nth-child(1) { border-top-color: var(--cyan); }
  .pub:nth-child(2) { border-top-color: var(--violet); }
  .pub:nth-child(3) { border-top-color: #fff; }
  .pub .num {
    font-family: var(--head); font-size: 14px; letter-spacing: .14em; text-transform: uppercase; color: var(--fog);
  }
  .pub:nth-child(1) .num { color: var(--cyan); }
  .pub:nth-child(2) .num { color: var(--violet-soft); }
  .pub h3 { font-size: clamp(32px, 3.4vw, 48px); letter-spacing: -.01em; }
  .pub p { color: var(--fog); font-size: 16px; line-height: 1.65; font-weight: 300; }

  /* GAMES */
  .games { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
  .game {
    display: flex; flex-direction: column;
    border-radius: 24px; overflow: hidden;
    background: var(--ink-2);
    border: 1px solid var(--line);
    transition: transform .3s ease, border-color .3s ease;
  }
  .game:hover { transform: translateY(-6px); border-color: var(--cyan); }
  .game .thumb {
    aspect-ratio: 16/10; position: relative; overflow: hidden;
    background:
      radial-gradient(circle at 70% 30%, rgba(122,43,255,.5), transparent 55%),
      radial-gradient(circle at 20% 80%, rgba(6,190,252,.4), transparent 55%),
      linear-gradient(135deg, #15183a, #090b20);
  }
  .game:nth-child(2) .thumb {
    background:
      radial-gradient(circle at 30% 30%, rgba(6,190,252,.55), transparent 55%),
      radial-gradient(circle at 80% 80%, rgba(122,43,255,.45), transparent 55%),
      linear-gradient(135deg, #0f1130, #1a1b42);
  }
  .game.coming-soon .thumb {
    background:
      repeating-linear-gradient(45deg, rgba(255,255,255,.04) 0 20px, transparent 20px 40px),
      radial-gradient(circle at 50% 50%, rgba(122,43,255,.35), transparent 60%),
      linear-gradient(135deg, #0c0e28, #14163a);
  }
  .game.coming-soon .thumb-ph .title { color: var(--cyan-soft); }
  .game.coming-soon { border-style: dashed; }
  .game.coming-soon .go { color: var(--cyan); border-color: var(--cyan); }
  .game.coming-soon .go:hover { background: var(--cyan); color: var(--ink); }
  .thumb-ph {
    position: absolute; inset: 0; padding: 28px;
    display: flex; flex-direction: column; justify-content: space-between;
    font-family: var(--head); font-size: 11px; letter-spacing: .2em; text-transform: uppercase; color: var(--fog);
  }
  .thumb-ph .title {
    font-size: clamp(40px, 4vw, 56px); letter-spacing: -.01em; color: #fff;
    line-height: 1;
  }
  .game .body { padding: 32px; display: flex; flex-direction: column; gap: 14px; }
  .game h3 { font-size: clamp(28px, 2.8vw, 40px); letter-spacing: -.01em; }
  .game p.desc { color: var(--fog); font-size: 15px; line-height: 1.65; font-weight: 300; }
  .game .go {
    margin-top: 14px; align-self: flex-start;
    display: inline-flex; align-items: center; gap: 12px;
    font-family: var(--head); font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--cyan); padding: 10px 18px; border: 1px solid var(--cyan); border-radius: 999px;
    transition: all .2s ease;
  }
  .game:nth-child(2) .go { color: var(--violet-soft); border-color: var(--violet-soft); }
  .game .go:hover { background: var(--cyan); color: var(--ink); }
  .game:nth-child(2) .go:hover { background: var(--violet-soft); color: var(--ink); }

  /* NEXT JAM panel */
  .next-jam {
    display: grid; grid-template-columns: 1fr auto; align-items: center; gap: 48px;
    padding: 56px; border-radius: 32px;
    background:
      radial-gradient(ellipse at 100% 100%, rgba(122,43,255,.25), transparent 55%),
      radial-gradient(ellipse at 0% 0%, rgba(6,190,252,.18), transparent 55%),
      var(--ink-2);
    border: 1px solid var(--line);
    margin-bottom: 80px;
  }
  .next-jam .k {
    font-family: var(--head); font-size: 12px; letter-spacing: .2em; text-transform: uppercase;
    color: var(--cyan); margin-bottom: 14px;
  }
  .next-jam h3 { font-size: clamp(36px, 4.5vw, 64px); letter-spacing: -.01em; }
  .next-jam h3 .a { color: var(--violet-soft); }
  .next-jam p { color: var(--fog); margin-top: 14px; font-size: 16px; max-width: 520px; font-weight: 300; }

  .clock { display: flex; gap: 16px; }
  .clock .u {
    text-align: center; min-width: 88px; padding: 18px 6px; border-radius: 16px;
    background: rgba(255,255,255,.04); border: 1px solid var(--line);
  }
  .clock .v { font-family: var(--head); font-size: 48px; line-height: 1; color: #fff; }
  .clock .l {
    font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: var(--mute);
    margin-top: 6px; font-family: var(--head);
  }

  /* JAM ARCHIVE */
  .year { margin-bottom: 56px; }
  .year-head {
    display: grid; grid-template-columns: auto 1fr auto; gap: 28px; align-items: baseline;
    padding-bottom: 18px; border-bottom: 1px solid var(--line); margin-bottom: 8px;
  }
  .year-head .y { font-family: var(--head); font-size: 72px; line-height: .9; color: #fff; letter-spacing: -.02em; }
  .year-head .y .a { color: var(--cyan); }
  .year-head .kick {
    font-family: var(--head); font-size: 12px; letter-spacing: .16em; text-transform: uppercase;
    color: var(--violet-soft); align-self: center; padding-bottom: 14px;
  }
  .year-head .sum {
    font-size: 13px; letter-spacing: .1em; text-transform: uppercase; color: var(--mute);
    text-align: right; font-family: var(--head);
  }

  .jam-row {
    display: grid;
    grid-template-columns: 90px 1fr 180px 110px 110px 24px;
    gap: 24px; align-items: center;
    padding: 18px 8px;
    border-bottom: 1px solid var(--line-2);
    transition: background .2s ease, border-color .2s ease, padding .2s ease;
  }
  .jam-row:hover { background: rgba(255,255,255,.03); border-bottom-color: var(--cyan); padding-left: 16px; }
  .jam-row .d { font-family: var(--head); font-size: 11px; letter-spacing: .12em; color: var(--mute); text-transform: uppercase; }
  .jam-row .n { font-family: var(--head); font-size: 18px; line-height: 1.2; }
  .jam-row .t { font-family: var(--head); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: var(--cyan); }
  .jam-row.sp .t { color: var(--violet-soft); }
  .jam-row.sp .n { color: var(--violet-soft); }
  .jam-row .s { font-size: 12px; color: var(--fog); text-align: right; font-family: var(--head); }
  .jam-row .s b { color: #fff; font-weight: 400; }
  .jam-row .go {
    color: var(--mute); justify-self: end;
    transition: color .2s ease, transform .2s ease; font-size: 18px;
  }
  .jam-row:hover .go { color: var(--cyan); transform: translate(4px, -4px); }

  @media (max-width: 880px) {
    .jam-row { grid-template-columns: 1fr auto; gap: 6px 16px; padding: 16px 0; }
    .jam-row:hover { padding-left: 0; }
    .jam-row .d { order: 1; }
    .jam-row .t { order: 2; text-align: right; }
    .jam-row .n { order: 3; grid-column: 1 / -1; }
    .jam-row .s { order: 4; grid-column: 1 / -1; text-align: left; }
    .jam-row .go { display: none; }
  }

  /* CLOSEOUT */
  .closeout {
    padding: clamp(100px, 14vw, 180px) 0;
    position: relative; overflow: hidden;
    background:
      radial-gradient(ellipse at 20% 10%, rgba(122,43,255,.35), transparent 55%),
      radial-gradient(ellipse at 80% 90%, rgba(6,190,252,.3), transparent 55%),
      var(--ink);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    text-align: center;
  }
  .closeout .kicker { margin-bottom: 28px; display: inline-block; }
  .closeout h2 {
    font-size: clamp(64px, 11vw, 200px); line-height: .92; letter-spacing: -.02em;
    max-width: 14ch; margin: 0 auto 32px;
  }
  .closeout h2 .a { color: var(--cyan); }
  .closeout h2 .b { color: var(--violet-soft); }
  .closeout p.deck {
    max-width: 600px; margin: 0 auto 44px;
    color: var(--fog); font-size: 18px; line-height: 1.65; font-weight: 300;
  }
  .close-row { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  /* FOOTER */
  .foot {
    padding: 56px 0 40px; border-top: 1px solid var(--line);
    background: var(--ink);
  }
  .foot .container {
    display: grid; grid-template-columns: 2fr 1fr 1fr auto; gap: 40px; align-items: start;
  }
  .foot .col b {
    display: block; font-family: var(--head); color: #fff; margin-bottom: 14px;
    font-size: 13px; letter-spacing: .12em; text-transform: uppercase;
  }
  .foot .col a {
    display: block; padding: 4px 0; color: var(--fog); font-size: 14px; font-weight: 300;
  }
  .foot .col a:hover { color: var(--cyan); }
  .foot .colophon { color: var(--mute); font-size: 12px; font-weight: 300; max-width: 320px; }
  .foot .colophon .big {
    font-family: var(--head); font-size: 22px; color: #fff; margin-bottom: 10px;
    letter-spacing: -.01em; line-height: 1.1;
  }

  @media (max-width: 880px) {
    .foot .container { grid-template-columns: 1fr 1fr; gap: 28px; }
  }

  /* RESPONSIVE */
  @media (max-width: 980px) {
    .pub-grid { grid-template-columns: 1fr; gap: 16px; }
    .games { grid-template-columns: 1fr; }
    .next-jam { grid-template-columns: 1fr; padding: 36px; }
    .year-head { grid-template-columns: 1fr auto; gap: 8px 20px; }
    .year-head .sum { grid-column: 1 / -1; text-align: left; }
    .nav-links { display: none; }
  }
</style>

</body>
</html>
