---
import Layout from '../layouts/Layout.astro';
import { jams } from '../data/jams';
import { games } from '../data/games';

const totalParticipants = jams.reduce((sum, jam) => sum + jam.participants, 0);
const totalSubmissions = jams.reduce((sum, jam) => sum + jam.submissions, 0);
const recentJams = jams.slice(0, 3);
---

<Layout title="ScoreSpace - Make games. Play games.">
  <section class="diagonal-split">
    <div class="hero-split fade-in fade-in-delay-1">
      <div class="hero-left">
        <h1 class="reveal-text">
          <span class="line-1">
            <span class="word">SCORESPACE</span>
            <span class="word">IS</span>
            <span class="word">A</span>
            <span class="word cyan">GAME</span>
            <span class="word cyan">PUBLISHER</span>
          </span>
          <span class="line-2">
            <span class="word">FUELED</span>
            <span class="word">BY</span>
            <span class="word purple nowrap">MONTHLY GAMEJAMS.</span>
          </span>
        </h1>
      </div>
      <div class="hero-right">
        <div class="icon-stat cyan-stat">
          <span class="stat-icon">💻</span>
          <span class="stat-number">120+</span>
          <span class="stat-label">Avg Submissions</span>
        </div>
        <div class="icon-stat purple-stat">
          <span class="stat-icon">🎮</span>
          <span class="stat-number">5M+</span>
          <span class="stat-label">Lifetime Players</span>
        </div>
      </div>
    </div>

    <div class="split-container">
      <a href={`${import.meta.env.BASE_URL}jams/`} class="split-side split-jams fade-in fade-in-delay-2">
        <div class="split-content">
          <h2>JAMS</h2>
          <p class="split-tagline">Join the community</p>
          <div class="split-countdown">
            <span class="countdown-mini" id="countdown-mini">Next jam in <strong id="days-mini">--</strong>d <strong id="hours-mini">--</strong>h</span>
          </div>
          <span class="split-cta">Enter →</span>
        </div>
      </a>

      <a href={`${import.meta.env.BASE_URL}games/`} class="split-side split-games fade-in fade-in-delay-3">
        <div class="split-content">
          <h2>GAMES</h2>
          <p class="split-tagline">Get published</p>
          <p class="split-description">From jam to published</p>
          <span class="split-cta">Enter →</span>
        </div>
      </a>
    </div>
  </section>

  <section class="discord-cta">
    <div class="container">
      <a href="https://discord.gg/kCM89sr" target="_blank" rel="noopener noreferrer" class="btn btn-discord fade-in fade-in-delay-4">
        Join the Discord
      </a>
    </div>
  </section>

  <section class="recent-jams">
    <div class="container">
      <h2 class="fade-in fade-in-delay-5">Recent Jams</h2>
      <div class="jams-grid">
        {recentJams.map((jam, index) => {
          const isSpeedJam = jam.name.toLowerCase().includes('speedjam') || jam.name.toLowerCase().includes('foddian');
          const delayClass = `fade-in-delay-${6 + index}`;
          return (
          <a href={jam.url} target="_blank" rel="noopener noreferrer" class={`jam-card fade-in ${delayClass} ${isSpeedJam ? 'speedjam' : ''}`}>
            <div class="jam-content">
              <div class="jam-info">
                <h3>{jam.name}</h3>
                <div class="jam-date">{new Date(jam.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
                <div class="jam-stats">
                  <div class="stat">
                    <span class="stat-value">{jam.participants.toLocaleString()}</span>
                    <span class="stat-label">Participants</span>
                  </div>
                  <div class="stat">
                    <span class="stat-value">{jam.submissions}</span>
                    <span class="stat-label">Submissions</span>
                  </div>
                </div>
              </div>
              {jam.theme && <div class="jam-theme">{jam.theme}</div>}
            </div>
          </a>
        );
        })}
      </div>
      <div class="section-cta">
        <a href={`${import.meta.env.BASE_URL}jams/`} class="btn btn-secondary">View All Jams</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Diagonal Split Hero */
  .diagonal-split {
    min-height: 80vh;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .hero-split {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 6rem 8rem 3rem 12rem;
    max-width: 100%;
    margin: 0;
    gap: 4rem;
  }

  .hero-left {
    flex: 1;
    max-width: 650px;
  }

  .hero-left h1 {
    font-size: 4rem;
    font-weight: 900;
    letter-spacing: 0.02em;
    line-height: 1.1;
    color: var(--color-text);
  }

  .reveal-text .line-1,
  .reveal-text .line-2 {
    display: block;
  }

  .reveal-text .word {
    display: inline-block;
    opacity: 0;
    transform: translateY(20px);
    animation: revealWord 0.5s ease forwards;
  }

  .reveal-text .line-1 .word:nth-child(1) { animation-delay: 0.1s; }
  .reveal-text .line-1 .word:nth-child(2) { animation-delay: 0.2s; }
  .reveal-text .line-1 .word:nth-child(3) { animation-delay: 0.3s; }
  .reveal-text .line-1 .word:nth-child(4) { animation-delay: 0.4s; }
  .reveal-text .line-1 .word:nth-child(5) { animation-delay: 0.5s; }

  .reveal-text .line-2 .word:nth-child(1) { animation-delay: 0.7s; }
  .reveal-text .line-2 .word:nth-child(2) { animation-delay: 0.8s; }
  .reveal-text .line-2 .word:nth-child(3) { animation-delay: 0.9s; }

  .nowrap {
    white-space: nowrap;
  }

  @keyframes revealWord {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-left h1 .cyan {
    color: var(--color-jams);
  }

  .hero-left h1 .purple {
    color: var(--color-games);
  }

  .hero-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .icon-stat {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .icon-stat .stat-icon {
    font-size: 2.5rem;
  }

  .icon-stat .stat-number {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
  }

  .cyan-stat .stat-number {
    color: var(--color-jams);
  }

  .purple-stat .stat-number {
    color: var(--color-games);
  }

  .icon-stat .stat-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    max-width: 80px;
    line-height: 1.3;
  }

  .split-container {
    display: flex;
    flex: 1;
    position: relative;
  }

  .split-side {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2rem;
    text-decoration: none;
    color: var(--color-text);
    transition: flex 0.4s ease, background-color 0.3s ease;
    position: relative;
    overflow: hidden;
  }

  .split-jams {
    background: linear-gradient(135deg, rgba(6, 190, 252, 0.15) 0%, rgba(6, 190, 252, 0.05) 100%);
    clip-path: polygon(0 0, 100% 0, 85% 100%, 0 100%);
    padding-right: 4rem;
  }

  .split-jams::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-left: 3px solid var(--color-jams);
    opacity: 0.5;
  }

  .split-games {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.05) 0%, rgba(139, 92, 246, 0.15) 100%);
    clip-path: polygon(15% 0, 100% 0, 100% 100%, 0 100%);
    margin-left: -15%;
    padding-left: 4rem;
  }

  .split-games::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    border-right: 3px solid var(--color-games);
    opacity: 0.5;
  }

  .split-side:hover {
    flex: 1.15;
  }

  .split-jams:hover {
    background: linear-gradient(135deg, rgba(6, 190, 252, 0.25) 0%, rgba(6, 190, 252, 0.1) 100%);
  }

  .split-games:hover {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(139, 92, 246, 0.25) 100%);
  }

  .split-content {
    text-align: center;
    max-width: 300px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .split-content h2 {
    font-size: 3rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
    letter-spacing: 0.1em;
  }

  .split-jams .split-content h2 {
    color: var(--color-jams);
  }

  .split-games .split-content h2 {
    color: var(--color-games);
  }

  .split-tagline {
    font-size: 1.1rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .split-countdown,
  .split-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 1.5rem;
  }

  .countdown-mini strong {
    color: var(--color-jams);
  }

  .split-cta {
    display: inline-block;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    font-weight: 600;
    transition: all 0.2s ease;
  }

  .split-jams .split-cta {
    border: 2px solid var(--color-jams);
    color: var(--color-jams);
  }

  .split-jams:hover .split-cta {
    background-color: var(--color-jams);
    color: var(--color-bg);
  }

  .split-games .split-cta {
    border: 2px solid var(--color-games);
    color: var(--color-games);
  }

  .split-games:hover .split-cta {
    background-color: var(--color-games);
    color: var(--color-bg);
  }

  .discord-cta {
    text-align: center;
    padding: 2rem 0 4rem;
  }

  @media (max-width: 768px) {
    .diagonal-split {
      min-height: auto;
    }

    .split-container {
      flex-direction: column;
    }

    .split-side {
      clip-path: none;
      margin: 0;
      padding: 3rem 2rem;
    }

    .split-jams {
      padding-right: 2rem;
      border-bottom: 1px solid var(--color-border);
    }

    .split-games {
      padding-left: 2rem;
      margin-left: 0;
    }

    .split-side:hover {
      flex: 1;
    }

    .split-content h2 {
      font-size: 2rem;
    }

    .hero-split {
      flex-direction: column;
      text-align: center;
      padding: 4rem 1.5rem 2rem;
      gap: 2rem;
    }

    .hero-left h1 {
      font-size: 2rem;
    }

    .hero-right {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: center;
      gap: 2rem;
    }

    .icon-stat .stat-number {
      font-size: 2.5rem;
    }

    .icon-stat .stat-icon {
      font-size: 2rem;
    }
  }

  .btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: var(--color-text);
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    color: var(--color-text);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-jams);
  }

  .btn-secondary:hover {
    background-color: var(--color-jams);
    color: var(--color-bg);
  }

  .btn-discord {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--color-accent);
    color: var(--color-text);
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }

  .btn-discord:hover {
    background-color: var(--color-accent-hover);
    color: var(--color-text);
    transform: translateY(-2px);
  }

  .recent-jams {
    padding: 4rem 0;
  }

  .recent-jams h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .jams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .jam-card {
    display: block;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.2s ease;
  }

  .jam-card:hover {
    border-color: var(--color-jams);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .jam-card.speedjam {
    border-color: rgba(0, 255, 12, 0.3);
  }

  .jam-card.speedjam:hover {
    border-color: #00ff0c;
  }

  .jam-card.speedjam .jam-theme {
    color: #00ff0c;
  }

  .jam-card.speedjam .stat-value {
    color: #00ff0c;
  }

  .jam-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .jam-info {
    flex: 1;
  }

  .jam-card h3 {
    font-size: 1.1rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .jam-theme {
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    color: #06befc;
    text-transform: uppercase;
    font-size: 1.05rem;
    letter-spacing: 0.5px;
    text-align: center;
    width: 120px;
    flex-shrink: 0;
    line-height: 1.3;
    word-wrap: break-word;
  }

  .jam-date {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .jam-stats {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-weight: 600;
    font-size: 1.1rem;
    color: #06befc;
  }

  .stat-label {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .section-cta {
    text-align: center;
  }

</style>

<script>
  // Countdown to next 3rd Friday at 3pm EST
  function getThirdFriday(year: number, month: number): Date {
    const firstDay = new Date(year, month, 1);
    const firstFriday = new Date(year, month, 1 + ((5 - firstDay.getDay() + 7) % 7));
    const thirdFriday = new Date(firstFriday);
    thirdFriday.setDate(firstFriday.getDate() + 14);
    // Set to 3pm EST (20:00 UTC)
    thirdFriday.setUTCHours(20, 0, 0, 0);
    return thirdFriday;
  }

  function getNextThirdFriday(): Date {
    const now = new Date();
    let year = now.getFullYear();
    let month = now.getMonth();

    let thirdFriday = getThirdFriday(year, month);

    if (now >= thirdFriday) {
      month++;
      if (month > 11) {
        month = 0;
        year++;
      }
      thirdFriday = getThirdFriday(year, month);
    }

    return thirdFriday;
  }

  function updateCountdown() {
    const target = getNextThirdFriday();
    const now = new Date();
    const diff = target.getTime() - now.getTime();

    if (diff <= 0) {
      location.reload();
      return;
    }

    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));

    // Update mini countdown on diagonal split
    const daysMiniEl = document.getElementById('days-mini');
    const hoursMiniEl = document.getElementById('hours-mini');

    if (daysMiniEl) daysMiniEl.textContent = days.toString();
    if (hoursMiniEl) hoursMiniEl.textContent = hours.toString();
  }

  updateCountdown();
  setInterval(updateCountdown, 1000);
</script>
