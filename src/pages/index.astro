---
import Layout from '../layouts/Layout.astro';
import { jams } from '../data/jams';
import { games } from '../data/games';

const totalParticipants = jams.reduce((sum, jam) => sum + jam.participants, 0);
const totalSubmissions = jams.reduce((sum, jam) => sum + jam.submissions, 0);
const recentJams = jams.slice(0, 3);
---

<Layout title="ScoreSpace - Make games. Play games.">
  <section class="hero">
    <div class="container">
      <div class="hero-split">
        <div class="hero-left">
          <img src={`${import.meta.env.BASE_URL}logo.png`} alt="ScoreSpace" class="hero-logo fade-in fade-in-delay-1" />
          <p class="tagline fade-in fade-in-delay-2">Make games. Play games.</p>
          <p class="description fade-in fade-in-delay-3">
ScoreSpace is a game publisher fueled by monthly gamejams.
          </p>
          <div class="cta-buttons fade-in fade-in-delay-4">
            <a href={`${import.meta.env.BASE_URL}jams/`} class="btn btn-primary">View Jams</a>
            <a href={`${import.meta.env.BASE_URL}games/`} class="btn btn-secondary">Play Games</a>
          </div>
        </div>
        <div class="hero-right">
          <div class="stats-grid">
            <div class="stat-card fade-in fade-in-delay-3">
              <span class="stat-number">100+</span>
              <span class="stat-label">Games Submitted Per Month</span>
            </div>
            <div class="stat-card fade-in fade-in-delay-4">
              <span class="stat-number" data-target={totalParticipants}>0</span>
              <span class="stat-label">Lifetime Participants</span>
            </div>
            <div class="stat-card fade-in fade-in-delay-5">
              <span class="stat-number" data-target={totalSubmissions}>0</span>
              <span class="stat-label">Games Submitted</span>
            </div>
            <div class="stat-card fade-in fade-in-delay-6">
              <span class="stat-number">5m+</span>
              <span class="stat-label">Lifetime Players</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="recent-jams">
    <div class="container">
      <h2 class="fade-in fade-in-delay-5">Recent Jams</h2>
      <div class="jams-grid">
        {recentJams.map((jam, index) => {
          const isSpeedJam = jam.name.toLowerCase().includes('speedjam') || jam.name.toLowerCase().includes('foddian');
          const delayClass = `fade-in-delay-${6 + index}`;
          return (
          <a href={jam.url} target="_blank" rel="noopener noreferrer" class={`jam-card fade-in ${delayClass} ${isSpeedJam ? 'speedjam' : ''}`}>
            <div class="jam-content">
              <div class="jam-info">
                <h3>{jam.name}</h3>
                <div class="jam-date">{new Date(jam.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</div>
                <div class="jam-stats">
                  <div class="stat">
                    <span class="stat-value">{jam.participants.toLocaleString()}</span>
                    <span class="stat-label">Participants</span>
                  </div>
                  <div class="stat">
                    <span class="stat-value">{jam.submissions}</span>
                    <span class="stat-label">Submissions</span>
                  </div>
                </div>
              </div>
              {jam.theme && <div class="jam-theme">{jam.theme}</div>}
            </div>
          </a>
        );
        })}
      </div>
      <div class="section-cta">
        <a href={`${import.meta.env.BASE_URL}jams/`} class="btn btn-secondary">View All Jams</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    padding: 6rem 0 4rem;
    background: linear-gradient(180deg, var(--color-bg-secondary) 0%, var(--color-bg) 100%);
  }

  .hero-split {
    display: flex;
    align-items: center;
    gap: 4rem;
  }

  .hero-left {
    flex: 1;
    text-align: left;
  }

  .hero-right {
    flex: 1;
  }

  .hero-logo {
    display: block;
    max-width: 350px;
    width: 100%;
    height: auto;
    margin-bottom: 1rem;
    margin-left: -8px;
  }

  .tagline {
    font-family: 'Russo One', sans-serif;
    font-size: 1.5rem;
    color: var(--color-text);
    margin-bottom: 1.5rem;
  }

  .description {
    max-width: 500px;
    margin-bottom: 2rem;
    color: var(--color-text-muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .stat-card {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.25rem;
  }

  .stat-label {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .hero-split {
      flex-direction: column;
      text-align: center;
    }

    .hero-left {
      text-align: center;
    }

    .hero-logo {
      margin: 0 auto 1rem;
    }

    .cta-buttons {
      justify-content: center;
    }

    .description {
      margin: 0 auto 2rem;
    }
  }

  .btn {
    display: inline-block;
    padding: 0.875rem 2rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 1rem;
    transition: all 0.2s ease;
  }

  .btn-primary {
    background-color: var(--color-accent);
    color: var(--color-text);
  }

  .btn-primary:hover {
    background-color: var(--color-accent-hover);
    color: var(--color-text);
  }

  .btn-secondary {
    background-color: transparent;
    color: var(--color-text);
    border: 2px solid var(--color-border);
  }

  .btn-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  .stats {
    padding: 4rem 0;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
  }

  .stat-card {
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 0.5rem;
  }

  .stat-label {
    color: var(--color-text-muted);
    font-size: 0.95rem;
  }

  .recent-jams {
    padding: 4rem 0;
  }

  .recent-jams h2 {
    font-size: 2rem;
    margin-bottom: 2rem;
    text-align: center;
  }

  .jams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .jam-card {
    display: block;
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.2s ease;
  }

  .jam-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    color: var(--color-text);
  }

  .jam-card.speedjam {
    border-color: rgba(0, 255, 12, 0.3);
  }

  .jam-card.speedjam:hover {
    border-color: #00ff0c;
  }

  .jam-card.speedjam .jam-theme {
    color: #00ff0c;
  }

  .jam-card.speedjam .stat-value {
    color: #00ff0c;
  }

  .jam-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .jam-info {
    flex: 1;
  }

  .jam-card h3 {
    font-size: 1.1rem;
    line-height: 1.3;
    margin-bottom: 0.5rem;
  }

  .jam-theme {
    font-family: 'Lato', sans-serif;
    font-weight: 700;
    color: #06befc;
    text-transform: uppercase;
    font-size: 1.05rem;
    letter-spacing: 0.5px;
    text-align: center;
    width: 120px;
    flex-shrink: 0;
    line-height: 1.3;
    word-wrap: break-word;
  }

  .jam-date {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .jam-stats {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }

  .stat {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-weight: 600;
    font-size: 1.1rem;
    color: #06befc;
  }

  .stat-label {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .section-cta {
    text-align: center;
  }

  @media (max-width: 640px) {
    .hero h1 {
      font-size: 2.5rem;
    }

    .tagline {
      font-size: 1.25rem;
    }

    .stat-number {
      font-size: 2rem;
    }
  }
</style>

<script>
  // Animated stat counters
  function animateCounter(element: Element, target: number, duration: number = 1500) {
    const start = 0;
    const startTime = performance.now();

    function update(currentTime: number) {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);

      // Ease out cubic for smooth deceleration
      const easeOut = 1 - Math.pow(1 - progress, 3);
      const current = Math.floor(start + (target - start) * easeOut);

      element.textContent = current.toLocaleString();

      if (progress < 1) {
        requestAnimationFrame(update);
      } else {
        element.textContent = target.toLocaleString();
      }
    }

    requestAnimationFrame(update);
  }

  // Observe stat cards and trigger counter animation
  const statObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const statNumber = entry.target.querySelector('.stat-number[data-target]');
        if (statNumber) {
          const target = parseInt(statNumber.getAttribute('data-target') || '0', 10);
          animateCounter(statNumber, target);
        }
        statObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.stat-card').forEach(card => {
    statObserver.observe(card);
  });
</script>
