---
interface Props {
  title: string;
  description?: string;
}

const { title, description = "ScoreSpace - Make games. Play games." } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}favicon.png`} />
    <link rel="apple-touch-icon" href={`${import.meta.env.BASE_URL}apple-touch-icon.png`} />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Lato:wght@400;700;900&family=Russo+One&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body>
    <div class="vignette" aria-hidden="true"></div>
    <a href="https://gamesbeat.com/scorespace-raises-525k-to-scale-game-jam-powered-studio-on-discord-activities/" target="_blank" rel="noopener noreferrer" class="announcement-banner">
      <svg class="gamesbeat-logo" viewBox="0 0 30 20" xmlns="http://www.w3.org/2000/svg">
        <text x="0" y="16" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="white">GB</text>
      </svg>
      ScoreSpace raises $525K to scale game jam-powered studio
    </a>
    <nav class="nav">
      <div class="nav-container">
        <div class="nav-links nav-links-left">
          <a href={`${import.meta.env.BASE_URL}jams/`}>JAMS</a>
        </div>
        <a href={`${import.meta.env.BASE_URL}`} class="logo">
          <img src={`${import.meta.env.BASE_URL}logo.png`} alt="ScoreSpace" class="logo-img" />
        </a>
        <div class="nav-links nav-links-right">
          <a href={`${import.meta.env.BASE_URL}games/`} class="nav-games">GAMES</a>
        </div>
      </div>
    </nav>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="footer-container">
        <p>&copy; {new Date().getFullYear()} ScoreSpace. Make games. Play games.</p>
        <div class="footer-links">
          <a href="https://itch.io/jams/hosted-by-scorespace" target="_blank" rel="noopener noreferrer">itch.io</a>
          <a href="https://scorespace.net" target="_blank" rel="noopener noreferrer">scorespace.net</a>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  :root {
    --color-bg: #01071c;
    --color-bg-secondary: #0a1229;
    --color-text: #fffcec;
    --color-text-muted: #a8a8a8;
    --color-accent: #06befc;
    --color-accent-hover: #38cfff;
    --color-border: #1a2744;
    --font-heading: 'Lato', sans-serif;
    --font-body: 'Lato', sans-serif;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: var(--font-body);
    background-color: var(--color-bg);
    color: var(--color-text);
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  main {
    flex: 1;
  }

  a {
    color: var(--color-text);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  a:hover {
    color: var(--color-accent);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
    font-weight: 700;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Animation Keyframes */
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Fade-in utility classes */
  .fade-in {
    opacity: 0;
    animation: fadeInUp 0.6s ease forwards;
  }

  .fade-in-delay-1 { animation-delay: 0.1s; }
  .fade-in-delay-2 { animation-delay: 0.2s; }
  .fade-in-delay-3 { animation-delay: 0.3s; }
  .fade-in-delay-4 { animation-delay: 0.4s; }
  .fade-in-delay-5 { animation-delay: 0.5s; }
  .fade-in-delay-6 { animation-delay: 0.6s; }
  .fade-in-delay-7 { animation-delay: 0.7s; }
  .fade-in-delay-8 { animation-delay: 0.8s; }

  /* Scroll-triggered animation classes */
  .scroll-fade-in {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .scroll-fade-in.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Vignette */
  .vignette {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse at center, transparent 40%, rgba(0, 0, 0, 0.4) 100%);
  }
</style>

<style>
  .announcement-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.25rem;
    background: linear-gradient(90deg, #00d4ff 0%, #8b5cf6 100%);
    color: white;
    text-align: center;
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .gamesbeat-logo {
    height: 16px;
    width: auto;
  }

  .announcement-banner:hover {
    opacity: 0.9;
    color: white;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    transition: backdrop-filter 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
  }

  .nav.scrolled {
    backdrop-filter: blur(10px);
    background-color: rgba(1, 7, 28, 0.85);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.25rem 1.5rem;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 4rem;
  }

  .logo {
    display: flex;
    align-items: center;
  }

  .logo-img {
    height: 40px;
    width: auto;
    transition: opacity 0.2s ease;
  }

  .logo:hover .logo-img {
    opacity: 0.8;
  }

  .nav-links {
    display: flex;
    gap: 2rem;
  }

  .nav-links a {
    font-weight: 500;
    font-size: 0.95rem;
    transition: transform 0.2s ease, color 0.2s ease;
  }

  .nav-links a:hover {
    transform: scale(1.1);
    color: var(--color-accent);
  }

  .nav-links a.nav-games:hover {
    color: #8b5cf6;
  }

  .footer {
    background-color: var(--color-bg-secondary);
    border-top: 1px solid var(--color-border);
    padding: 2rem 0;
    margin-top: 4rem;
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .footer-container p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
  }

  .footer-links a {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 640px) {
    .nav-links {
      gap: 1rem;
    }

    .footer-container {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

<script>
  // Navbar scroll effect
  const nav = document.querySelector('.nav');

  function handleScroll() {
    if (window.scrollY > 50) {
      nav?.classList.add('scrolled');
    } else {
      nav?.classList.remove('scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll(); // Check initial state

  // Intersection Observer for scroll-triggered animations
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.1
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry, index) => {
      if (entry.isIntersecting) {
        // Add staggered delay for cards within a grid
        const parent = entry.target.parentElement;
        if (parent?.classList.contains('jams-grid') || parent?.classList.contains('games-grid')) {
          const siblings = Array.from(parent.children);
          const cardIndex = siblings.indexOf(entry.target);
          entry.target.style.transitionDelay = `${cardIndex * 0.1}s`;
        }
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Observe all scroll-fade-in elements
  document.querySelectorAll('.scroll-fade-in').forEach(el => {
    observer.observe(el);
  });

</script>
